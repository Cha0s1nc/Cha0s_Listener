{
  "name": "cha0s-listener",
  "version": "1.0.1",
  "description": "Cha0s Bot Listener — OBS & Jellyfin bridge with dashboard",
  "main": "electron/main.js",
  "bin": "electron/main.js",
  "scripts": {
    "start": "node listener.js",
    "electron": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.cha0sinc.listener",
    "productName": "Cha0s Listener",
    "files": [
      "electron/**/*",
      "listener.js",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "electron-store": "^8.0.0",
    "express": "^4.18.2",
    "obs-websocket-js": "^5.0.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
